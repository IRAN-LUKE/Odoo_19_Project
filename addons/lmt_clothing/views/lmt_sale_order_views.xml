<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="lmt_sale_order_view_list" model="ir.ui.view">
        <field name="name">lmt_sale_order_view_list</field>
        <field name="model">lmt.sale.order</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="lmt_sale_order_view_form" model="ir.ui.view">
        <field name="name">lmt_sale_order_view_form</field>
        <field name="model">lmt.sale.order</field>
        <field name="arch" type="xml">
            <form string="lmt_sale_order_view_form">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="New"/>
                        </h1>
                    </div>
                    <group>

                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="lmt_sale_order_action" model="ir.actions.act_window">
        <field name="name">Sale</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">lmt.sale.order</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
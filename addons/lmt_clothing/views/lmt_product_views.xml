<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="lmt_product_view_list" model="ir.ui.view">
        <field name="name">lmt_product_view_list</field>
        <field name="model">lmt.product</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="product_id" optional="hide"/>
                <field name="clothing_type"/>
                <field name="clothing_size"/>
                <field name="qty"/>
<!--                <field name="is_raw_material" widget="boolean_toggle" readonly="1"/>-->
                <field name="company_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="lmt_product_view_form" model="ir.ui.view">
        <field name="name">lmt_product_view_form</field>
        <field name="model">lmt.product</field>
        <field name="arch" type="xml">
            <form string="lmt_product_view_form">
                <sheet>
                    <group>
                        <group>
                            <div class="oe_title">
                                <h1>
                                    <field name="name" placeholder="New"/>
                                </h1>
                            </div>
                        </group>
                        <group>
                            <field name="image" widget="image" class="oe_avatar" nolabel="1"/>
                        </group>
                    </group>
                    <group>
<!--                        <field name="is_raw_material"/>-->
                        <field name="clothing_type"/>
                        <field name="clothing_size"/>
                        <field name="product_id"/>
                        <field name="company_id"/>
                        <field name="currency_id"/>
                        <field name="sale_amount"/>
                        <field name="purchase_amount"/>
                        <field name="qty"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="lmt_product_view_kanban" model="ir.ui.view">
        <field name="name">lmt_product_view_kanban</field>
        <field name="model">lmt.product</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="clothing_type"/>
                <field name="clothing_size"/>
                <field name="qty"/>
                <field name="is_raw_material"/>
                <field name="image"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click o_kanban_record">
                            <div class="d-flex justify-content-between p-2">
                                <div class="flex-grow-1 pe-2">
                                    <div class="fw-bold fs-5">
                                        <field name="name"/>
                                    </div>
                                    <div>
                                        <strong>Type:</strong>
                                        <field name="clothing_type"/>
                                    </div>
                                    <div>
                                        <strong>Size:</strong>
                                        <field name="clothing_size"/>
                                    </div>
                                    <div>
                                        <strong>Qty:</strong>
                                        <field name="qty"/>
                                    </div>
                                </div>

                                <div class="d-flex align-items-start">
                                    <field name="image"
                                           widget="image"
                                           class="rounded"
                                           options="{
                                            'size': [100, 100]
                                       }"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="lmt_product_search" model="ir.ui.view">
        <field name="name">lmt_product_search</field>
        <field name="model">lmt.product</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="clothing_type"/>
                <field name="clothing_size"/>
                <filter name="filter_raw_material"
                        string="Raw Material"
                        domain="[('is_raw_material','=',True)]"/>
                <filter name="filter_finished"
                        string="Sale Product"
                        domain="[('is_raw_material','=',False)]"/>
                <group name="group_by">
                    <filter name="group_type"
                            string="Type"
                            context="{'group_by': 'clothing_type'}"/>
                    <filter name="group_size"
                            string="Size"
                            context="{'group_by': 'clothing_size'}"/>
                    <filter name="group_company"
                            string="Company"
                            context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="lmt_product_action" model="ir.actions.act_window">
        <field name="name">Product</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">lmt.product</field>
        <field name="view_mode">kanban,list,form</field>
    </record>
</odoo>
<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!-- Root menu -->
    <menuitem id="lmt_clothing_root" name="Clothing Store" sequence="10"
              web_icon="lmt_clothing,static/description/logo.png"/>

    <!-- Parent menu: Products -->
    <menuitem id="lmt_sale_menu"
              name="Sale"
              parent="lmt_clothing_root"
              sequence="10"/>

    <menuitem id="lmt_purchase_menu"
              name="Purchase"
              parent="lmt_clothing_root"
              sequence="20"/>

    <menuitem id="lmt_products_menu"
              name="Products"
              parent="lmt_clothing_root"
              sequence="30"/>

    <menuitem id="lmt_employee_menu"
              name="Employee"
              parent="lmt_clothing_root"
              action="lmt_employee_action"
              sequence="40"/>

    <menuitem id="lmt_menu_config"
              name="Configuration"
              parent="lmt_clothing_root"
              sequence="50"/>

    <!-- Child menus -->
    <!-- Product  -->
    <menuitem id="lmt_product"
              name="Product"
              parent="lmt_products_menu"
              action="lmt_product_action"
              sequence="10"/>

    <!-- Configuration -->
    <!-- Group Menu -->
    <menuitem id="lmt_cloth_size_group"
              name="Cloth"
              parent="lmt_menu_config"
              sequence="10"/>

    <menuitem id="lmt_product_size"
              name="Size"
              parent="lmt_cloth_size_group"
              action="lmt_product_size_action"
              sequence="1"/>

    <menuitem id="lmt_product_category"
              name="Category"
              parent="lmt_cloth_size_group"
              action="lmt_product_category_action"
              sequence="2"/>

    <!-- Group Menu -->
    <menuitem id="lmt_job_position_group"
              name="Job Position"
              parent="lmt_menu_config"
              sequence="20"/>

    <menuitem id="lmt_hr_job"
              name="Jobs"
              parent="lmt_job_position_group"
              action="lmt_job_action"
              sequence="1"/>

    <!--  Purchase  -->
    <menuitem id="lmt_purchase_purchase_menu"
              name="Purchase"
              parent="lmt_purchase_menu"
              action="lmt_purchase_order_action"
              sequence="10"/>

    <menuitem id="lmt_bill_menu"
              name="Bills"
              parent="lmt_purchase_menu"
              action="lmt_bill_action"
              sequence="20"/>

    <!--  Sale  -->
    <menuitem id="lmt_sale_sale_menu"
              name="Sale"
              parent="lmt_sale_menu"
              action="lmt_sale_order_action"
              sequence="10"/>

    <menuitem id="lmt_invoice_menu"
              name="Invoices"
              parent="lmt_sale_menu"
              action="lmt_invoice_action"
              sequence="20"/>

</odoo>
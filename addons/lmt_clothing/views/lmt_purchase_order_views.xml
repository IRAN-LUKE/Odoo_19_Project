<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="lmt_purchase_order_view_list" model="ir.ui.view">
        <field name="name">lmt.purchase.order.list</field>
        <field name="model">lmt.purchase.order</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="datetime"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'sent'"
                       decoration-success="state == 'purchase'"
                       decoration-muted="state in ('done', 'cancel')"/>
            </list>
        </field>
    </record>

    <record id="lmt_purchase_order_view_form" model="ir.ui.view">
        <field name="name">lmt.purchase.order.form</field>
        <field name="model">lmt.purchase.order</field>
        <field name="arch" type="xml">
            <form string="Purchase Order">
                <header>
                    <button name="action_send"
                            type="object"
                            string="Send to Vendor"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_purchase"
                            type="object"
                            string="Confirm Order"
                            class="btn-primary"
                            invisible="state not in ('draft', 'sent')"/>

                    <button name="action_create_bill"
                            type="object"
                            string="Create Vendor Bill"
                            class="btn-secondary"
                            invisible="state != 'purchase'"/>

                    <button name="action_lock"
                            type="object"
                            string="Lock"
                            invisible="state != 'purchase'"/>

                    <button name="action_cancel"
                            type="object"
                            string="Cancel"
                            invisible="state in ('done', 'cancel')"/>

                    <button name="action_draft"
                            type="object"
                            string="Reset to Draft"
                            invisible="state != 'cancel'"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,sent,purchase,done"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button"
                                type="object"
                                name="action_view_bills"
                                icon="fa-pencil-square-o"
                                invisible="invoice_count == 0">
                            <field name="invoice_count" widget="statinfo" string="Bills"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="partner_id"
                                   readonly="state not in ('draft', 'sent')"/>
                            <field name="datetime"
                                   readonly="state not in ('draft', 'sent')"/>
                        </group>
                        <group>
                            <field name="company_id" readonly="1"/>
                            <field name="currency_id" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Order Lines">
                            <field name="po_line_ids"
                                   readonly="state not in ('draft', 'sent')">
                                <list editable="bottom">
                                    <field name="lmt_product_id" string="Product"/>
                                    <field name="product_id" column_invisible="1"/>
                                    <field name="qty"/>
                                    <field name="price_unit"/>
                                    <field name="discount_amount"/>
                                    <field name="total_amount" readonly="1"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="currency_id" invisible="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <record id="lmt_purchase_order_action" model="ir.actions.act_window">
        <field name="name">Purchase Orders</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">lmt.purchase.order</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
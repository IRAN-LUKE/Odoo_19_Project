<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data noupdate="1">
        <record id="seq_lmt_purchase_order" model="ir.sequence">
            <field name="name">LMT Purchase Order</field>
            <field name="code">lmt.purchase.order</field>
            <field name="prefix">LMT-PO/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <record id="seq_lmt_sale_order" model="ir.sequence">
            <field name="name">LMT Sale Order</field>
            <field name="code">lmt.sale.order</field>
            <field name="prefix">LMT-SO/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>
    </data>
</odoo>